<% if (theme.about){ %>
<div class="widget-wrap">
  <h3 class="widget-title">个人简介</h3>
  <div class="widget">
    <% if (theme.about.avatar){ %>
    <div style="text-align:center;margin-bottom:10px;">
      <img src="<%- theme.about.avatar %>" alt="头像" style="width:100px;height:100px;border-radius:50%;">
    </div>
    <% } %>
    <% if (theme.about.name){ %>
    <p style="text-align:center;font-weight:bold;font-size:1.1em;margin-bottom:5px;"><%- theme.about.name %></p>
    <% } %>
    <% if (theme.about.description){ %>
    <p style="text-align:center;color:#666;"><%- theme.about.description %></p>
    <% } %>
  </div>
</div>
<% } %>
